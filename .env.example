# ══════════════════════════════════════════════════
# VANI — Environment Variables
# Copy this file to .env and fill in your values
# ══════════════════════════════════════════════════

# ─── Firebase (REQUIRED for Auth & Google Sign-In) ───────────────────────────
# Get these from: console.firebase.google.com
# → Your Project → Project Settings → General → Your Apps → Web App → Config
VITE_FIREBASE_API_KEY=AIzaSy...
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789012
VITE_FIREBASE_APP_ID=1:123456789012:web:abcdef1234567890

# ─── Google Gemini AI (REQUIRED for AI feedback & chatbot) ───────────────────
# Get from: https://makersuite.google.com/app/apikey
VITE_GEMINI_API_KEY=AIzaSy...

# ─── AssemblyAI (REQUIRED for speech-to-text transcription) ──────────────────
# Get from: https://www.assemblyai.com/app/account
VITE_ASSEMBLYAI_API_KEY=your_assemblyai_key_here

# ─── Azure Text-to-Speech (OPTIONAL — browser fallback used if missing) ──────
# Get from: portal.azure.com → Cognitive Services → Speech
VITE_AZURE_API_KEY=your_azure_speech_key_here
VITE_AZURE_REGION=centralindia

# ─── Supabase (OPTIONAL — only if you want database features) ────────────────
# Get from: supabase.com → Your Project → Settings → API
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here
